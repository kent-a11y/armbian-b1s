From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Builder <builder@local>
Date: Mon, 16 Jun 2025 00:00:00 +0800
Subject: [PATCH] arm64: dts: amlogic: add Meson GXM B1S board

Add device tree for the Amlogic S912 (Meson GXM) B1S TV box.

Hardware:
- SoC: Amlogic S912 (8-core Cortex-A53)
- RAM: 3GB DDR
- WiFi/BT: AP6255 (BCM43455 + BCM2045A0)
- Network: Internal 100M PHY (RMII)
- Storage: eMMC + MicroSD
- Video: HDMI 2.0 + CVBS
- Audio: HDMI + T9015 DAC + SPDIF
- IR: NEC protocol

Signed-off-by: Builder <builder@local>
---
 arch/arm64/boot/dts/amlogic/Makefile          |   1 +
 arch/arm64/boot/dts/amlogic/meson-gxm-b1s.dts | 399 +++++
 2 files changed, 400 insertions(+)
 create mode 100644 arch/arm64/boot/dts/amlogic/meson-gxm-b1s.dts

diff --git a/arch/arm64/boot/dts/amlogic/Makefile b/arch/arm64/boot/dts/amlogic/Makefile
index 1111111..2222222 100644
--- a/arch/arm64/boot/dts/amlogic/Makefile
+++ b/arch/arm64/boot/dts/amlogic/Makefile
@@ -55,2 +55,3 @@
 dtb-$(CONFIG_ARCH_MESON) += meson-gxm-q200.dtb
+dtb-$(CONFIG_ARCH_MESON) += meson-gxm-b1s.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-gxm-q201.dtb

diff --git a/arch/arm64/boot/dts/amlogic/meson-gxm-b1s.dts b/arch/arm64/boot/dts/amlogic/meson-gxm-b1s.dts
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/arch/arm64/boot/dts/amlogic/meson-gxm-b1s.dts
@@ -0,0 +1,401 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright (c) 2024 Community
+ *
+ * 基于 Amlogic Q200 3G 厂商 DTS 逆向生成
+ * 适用于 Amlogic S912 (Meson GXM) B1S 盒子
+ *
+ * 硬件特征:
+ *   - SoC: Amlogic S912 (Meson GXM), 8 核 Cortex-A53
+ *   - RAM: 3GB DDR
+ *   - 存储: eMMC + MicroSD
+ *   - 网络: 内置 100M 以太网 (RMII, 内部 PHY)
+ *   - WiFi/BT: AP6255 (BCM43455 SDIO WiFi + BCM2045A0 UART 蓝牙)
+ *   - USB: 1x USB 3.0 + 1x USB 2.0
+ *   - 视频输出: HDMI 2.0
+ *   - 音频: HDMI + 内置 DAC (T9015) + S/PDIF
+ *   - IR: NEC 协议红外接收
+ */
+
+/dts-v1/;
+
+#include <dt-bindings/input/input.h>
+#include <dt-bindings/leds/common.h>
+#include <dt-bindings/sound/meson-aiu.h>
+#include <dt-bindings/interrupt-controller/irq.h>
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/gpio/meson-gxbb-gpio.h>
+
+#include "meson-gxm.dtsi"
+
+/ {
+	compatible = "amlogic,b1s", "amlogic,s912", "amlogic,meson-gxm";
+	model = "Amlogic Meson GXM (S912) B1S";
+
+	aliases {
+		serial0 = &uart_AO;
+		serial1 = &uart_A;
+		ethernet0 = &ethmac;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	/* NOTE: 3GB 内存，实际大小通常由 U-Boot 在启动时传入 */
+	memory@0 {
+		device_type = "memory";
+		reg = <0x0 0x0 0x0 0xC0000000>;
+	};
+
+	/* 电源域定义*/
+
+	/* HDMI 5V 电源 - 对应厂商 DTS 中 hdmi5v_pwr_ctrl = <&gpio GPIODV_19 1> */
+	hdmi_5v: regulator-hdmi-5v {
+		compatible = "regulator-fixed";
+		regulator-name = "HDMI_5V";
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+		gpio = <&gpio GPIOH_3 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+		regulator-always-on;
+	};
+
+	vddio_ao18: regulator-vddio-ao18 {
+		compatible = "regulator-fixed";
+		regulator-name = "VDDIO_AO18";
+		regulator-min-microvolt = <1800000>;
+		regulator-max-microvolt = <1800000>;
+	};
+
+	vddio_boot: regulator-vddio-boot {
+		compatible = "regulator-fixed";
+		regulator-name = "VDDIO_BOOT";
+		regulator-min-microvolt = <1800000>;
+		regulator-max-microvolt = <1800000>;
+	};
+
+	vddao_3v3: regulator-vddao-3v3 {
+		compatible = "regulator-fixed";
+		regulator-name = "VDDAO_3V3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+	};
+
+	vcc_3v3: regulator-vcc-3v3 {
+		compatible = "regulator-fixed";
+		regulator-name = "VCC_3V3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+	};
+
+	/* eMMC 上电序列 - BOOT_9 为 eMMC 复位引脚 */
+	emmc_pwrseq: emmc-pwrseq {
+		compatible = "mmc-pwrseq-emmc";
+		reset-gpios = <&gpio BOOT_9 GPIO_ACTIVE_LOW>;
+	};
+
+	/* SDIO WiFi 供电 - AP6255 WIFI_REG_ON, 厂商 phandle 0x35 pin 0x55 = GPIOX_6 */
+	sdio_pwrseq: sdio-pwrseq {
+		compatible = "mmc-pwrseq-simple";
+		reset-gpios = <&gpio GPIOX_6 GPIO_ACTIVE_LOW>;
+		clocks = <&wifi32k>;
+		clock-names = "ext_clock";
+	};
+
+	/* WiFi 32K 时钟输出 */
+	wifi32k: wifi32k {
+		compatible = "pwm-clock";
+		#clock-cells = <0>;
+		clock-frequency = <32768>;
+		pwms = <&pwm_ef 0 30518 0>;
+	};
+
+	/* 音频相关 */
+
+	/* SPDIF 数字音频虚拟编解码器 */
+	spdif_dit: audio-codec-0 {
+		#sound-dai-cells = <0>;
+		compatible = "linux,spdif-dit";
+		sound-name-prefix = "DIT";
+	};
+
+	/* HDMI 5V 供电的模拟功放*/
+	dio2133: analog-amplifier {
+		compatible = "simple-audio-amplifier";
+		sound-name-prefix = "AU2";
+		VCC-supply = <&hdmi_5v>;
+		enable-gpios = <&gpio GPIOH_5 GPIO_ACTIVE_HIGH>;
+	};
+
+	/* 主声卡定义*/
+	sound {
+		compatible = "amlogic,gx-sound-card";
+		model = "B1S";
+		audio-aux-devs = <&dio2133>;
+		audio-widgets = "Line", "Lineout";
+		audio-routing = "AU2 INL", "ACODEC LOUT",
+				"AU2 INR", "ACODEC ROUT",
+				"Lineout", "AU2 OUTL",
+				"Lineout", "AU2 OUTR";
+
+		assigned-clocks = <&clkc CLKID_MPLL0>,
+				  <&clkc CLKID_MPLL1>,
+				  <&clkc CLKID_MPLL2>;
+		assigned-clock-parents = <0>, <0>, <0>;
+		assigned-clock-rates = <294912000>,
+				       <270950400>,
+				       <393216000>;
+
+		dai-link-0 {
+			sound-dai = <&aiu AIU_CPU CPU_I2S_FIFO>;
+		};
+
+		dai-link-1 {
+			sound-dai = <&aiu AIU_CPU CPU_SPDIF_FIFO>;
+		};
+
+		dai-link-2 {
+			sound-dai = <&aiu AIU_CPU CPU_I2S_ENCODER>;
+			dai-format = "i2s";
+			mclk-fs = <256>;
+
+			codec-0 {
+				sound-dai = <&aiu AIU_HDMI CTRL_I2S>;
+			};
+		};
+
+		dai-link-3 {
+			sound-dai = <&aiu AIU_CPU CPU_SPDIF_ENCODER>;
+
+			codec-0 {
+				sound-dai = <&spdif_dit>;
+			};
+		};
+
+		dai-link-4 {
+			sound-dai = <&aiu AIU_HDMI CTRL_OUT>;
+
+			codec-0 {
+				sound-dai = <&hdmi_tx>;
+			};
+		};
+	};
+
+	/* LED 指示灯 - 厂商 phandle 0x35 pin 0x09 = GPIOZ_9, active_low */
+	leds {
+		compatible = "gpio-leds";
+
+		led-blue {
+			color = <LED_COLOR_ID_BLUE>;
+			function = LED_FUNCTION_STATUS;
+			gpios = <&gpio GPIOZ_9 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+	};
+
+	/* CVBS 复合视频输出接口 */
+	cvbs-connector {
+		compatible = "composite-video-connector";
+
+		port {
+			cvbs_connector_in: endpoint {
+				remote-endpoint = <&cvbs_vdac_out>;
+			};
+		};
+	};
+
+	/* HDMI 接口 */
+	hdmi-connector {
+		compatible = "hdmi-connector";
+		type = "a";
+
+		port {
+			hdmi_connector_in: endpoint {
+				remote-endpoint = <&hdmi_tx_tmds_out>;
+			};
+		};
+	};
+
+	/* 电源按键 - 对应厂商 DTS 中 key_pin = <&gpio_ao GPIOAO_2 0> */
+	gpio-keys-polled {
+		compatible = "gpio-keys-polled";
+		poll-interval = <100>;
+
+		power-button {
+			label = "power";
+			linux,code = <KEY_POWER>;
+			gpios = <&gpio_ao GPIOAO_2 GPIO_ACTIVE_LOW>;
+		};
+	};
+
+	/* ADC 按键 */
+	adc-keys {
+		compatible = "adc-keys";
+		io-channels = <&saradc 0>;
+		io-channel-names = "buttons";
+		keyup-threshold-microvolt = <1710000>;
+
+		button-function {
+			label = "Update";
+			linux,code = <KEY_VENDOR>;
+			press-threshold-microvolt = <10000>;
+		};
+	};
+};
+
+/* ============================================ */
+/*          外设节点覆写 (dtsi overlay)          */
+/* ============================================ */
+
+/* 音频接口单元 */
+&aiu {
+	status = "okay";
+};
+
+/* CVBS 模拟视频 DAC */
+&cvbs_vdac {
+	status = "okay";
+};
+
+/* 以太网 - 内部 100M PHY (RMII) */
+&ethmac {
+	status = "okay";
+	phy-handle = <&internal_phy>;
+	phy-mode = "rmii";
+};
+
+/* HDMI 发送器 */
+&hdmi_tx {
+	status = "okay";
+	pinctrl-0 = <&hdmi_hpd_pins>, <&hdmi_i2c_pins>;
+	pinctrl-names = "default";
+	hdmi-supply = <&hdmi_5v>;
+};
+
+&hdmi_tx_tmds_port {
+	hdmi_tx_tmds_out: endpoint {
+		remote-endpoint = <&hdmi_connector_in>;
+	};
+};
+
+/* 红外遥控 - NEC 协议, GPIOAO_7 */
+&ir {
+	status = "okay";
+	pinctrl-0 = <&remote_input_ao_pins>;
+	pinctrl-names = "default";
+};
+
+/* SAR ADC */
+&saradc {
+	status = "okay";
+	vref-supply = <&vddio_ao18>;
+};
+
+/* eMMC 存储 */
+&sd_emmc_c {
+	status = "okay";
+	pinctrl-0 = <&emmc_pins>, <&emmc_ds_pins>;
+	pinctrl-1 = <&emmc_clk_gate_pins>;
+	pinctrl-names = "default", "clk-gate";
+
+	bus-width = <8>;
+	cap-mmc-highspeed;
+	mmc-ddr-1_8v;
+	mmc-hs200-1_8v;
+	max-frequency = <200000000>;
+	non-removable;
+	disable-wp;
+
+	mmc-pwrseq = <&emmc_pwrseq>;
+	vmmc-supply = <&vcc_3v3>;
+	vqmmc-supply = <&vddio_boot>;
+};
+
+/* SD 卡*/
+&sd_emmc_b {
+	status = "okay";
+	pinctrl-0 = <&sdcard_pins>;
+	pinctrl-1 = <&sdcard_clk_gate_pins>;
+	pinctrl-names = "default", "clk-gate";
+
+	bus-width = <4>;
+	cap-sd-highspeed;
+	max-frequency = <50000000>;
+	disable-wp;
+
+	cd-gpios = <&gpio CARD_6 GPIO_ACTIVE_LOW>;
+
+	vmmc-supply = <&vddao_3v3>;
+	vqmmc-supply = <&vddio_boot>;
+};
+
+/* SDIO (WiFi - AP6255/BCM43455) */
+&sd_emmc_a {
+	status = "okay";
+	pinctrl-0 = <&sdio_pins>;
+	pinctrl-1 = <&sdio_clk_gate_pins>;
+	pinctrl-names = "default", "clk-gate";
+
+	bus-width = <4>;
+	cap-sd-highspeed;
+	max-frequency = <100000000>;
+	non-removable;
+	disable-wp;
+
+	/* AP6255 WiFi 电源序列 */
+	mmc-pwrseq = <&sdio_pwrseq>;
+
+	vmmc-supply = <&vddao_3v3>;
+	vqmmc-supply = <&vddio_ao18>;
+
+	/* AP6255 WiFi (Broadcom BCM43455/brcmfmac) */
+	brcmf: wifi@1 {
+		reg = <1>;
+		compatible = "brcm,bcm4329-fmac";
+		/* WIFI_WAKE_HOST - 厂商 phandle 0x35 pin 0x56 = GPIOX_7 */
+		interrupt-parent = <&gpio>;
+		interrupts = <GPIOX_7 IRQ_TYPE_LEVEL_LOW>;
+		interrupt-names = "host-wake";
+	};
+};
+
+/* 调试串口 (AO UART, 115200 8N1) */
+&uart_AO {
+	status = "okay";
+	pinctrl-0 = <&uart_ao_a_pins>;
+	pinctrl-names = "default";
+};
+
+/* UART-A (AP6255 蓝牙, 4 线 UART 含硬件流控) */
+&uart_A {
+	status = "okay";
+	pinctrl-0 = <&uart_a_pins>, <&uart_a_cts_rts_pins>;
+	pinctrl-names = "default";
+	uart-has-rtscts;
+
+	/* AP6255 蓝牙 (Broadcom BCM2045A0/hci_bcm) */
+	bluetooth {
+		compatible = "brcm,bcm43438-bt";
+		/* BT_REG_ON - 厂商 phandle 0x35 pin 0x60 = GPIOX_17 */
+		shutdown-gpios = <&gpio GPIOX_17 GPIO_ACTIVE_HIGH>;
+		max-speed = <2000000>;
+		clocks = <&wifi32k>;
+		clock-names = "lpo";
+	};
+};
+
+/* USB 2.0/3.0 */
+&usb {
+	status = "okay";
+	dr_mode = "host";
+};
+
+/* USB 2.0 PHY */
+&usb2_phy0 {
+	phy-supply = <&vddao_3v3>;
+};
+
+&usb2_phy1 {
+	phy-supply = <&vddao_3v3>;
+};
-- 
2.34.1
