# Armbian userpatches/lib.config
# 本文件在家族配置 (config/sources/families/meson-gxl.conf) 之后被 source,
# 因此这里重新定义 uboot_custom_postprocess() 会覆盖家族里的同名函数。
#
# 目的:让自定义板 b1s 走真正的 Amlogic FIP 签名流程。
# 家族版本只对内置板(lepotato/khadas-vim2 等)执行后处理,b1s 不在名单内,
# 导致编译出的主线 U-Boot 不被签名,最终找不到 u-boot.bin.sd.bin(exit 43)。
#
# uboot_gxl_postprocess_ng 由 meson64_common.inc 提供,参数为 amlogic-boot-fip
# 仓库中对应板子的目录;该仓库由家族的 fetch_sources_tools__libreelec_amlogic_fip
# 钩子自动克隆到 $SRC/cache/sources/amlogic-boot-fip。
# S912(GXM)在 LibreELEC/amlogic-boot-fip 中可用的目录为 khadas-vim2,
# 其 bl30/bl2/bl31 等为 SoC 级固件,适用于所有 S912 板子。

uboot_custom_postprocess() {
	if [[ $BOARD == b1s ]]; then
		uboot_gxl_postprocess_ng "$SRC/cache/sources/amlogic-boot-fip/khadas-vim2"
	fi
}
